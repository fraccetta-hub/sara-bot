{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "sara-bot",
      "runtimeExecutable": "node",
      "runtimeArgs": ["index.js"],
      "port": 3000
    },
    {
      "name": "landingpage",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "landingpage", "-p", "4000", "--no-clipboard"],
      "port": 4000
    },
    {
      "name": "admin-static",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "public", "-p", "4100", "--no-clipboard"],
      "port": 4100
    }
  ]
}
